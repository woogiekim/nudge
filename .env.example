# Copy this file to ".env" in the same directory as notify.sh, then edit.
# notify.sh loads .env automatically. Real environment variables override it.

# ntfy server. The default public server is https://ntfy.sh
# For privacy, self-host ntfy and point this at your own instance.
NTFY_SERVER="https://ntfy.sh"

# REQUIRED: your topic name.
# ntfy.sh topics are PUBLIC — anyone who knows the name can read/send.
# Use a long, random, hard-to-guess string.
# Example: my-ai-alerts-8fK2pQz7vR
NTFY_TOPIC=""
